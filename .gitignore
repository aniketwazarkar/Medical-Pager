# ============================================
# Medical Pager - .gitignore
# ============================================

# --- Secrets & Environment Variables ---
# NEVER commit these
.env
.env.*
!.env.example
backend/.env
frontend/.env
frontend/.env.local
frontend/.env.production

# --- Go Build Artifacts ---
backend/tmp/
backend/*.exe
backend/*.out
backend/medical-pager
# Air (live reload) temp dir
tmp/

# --- Go Test & Coverage ---
*.test
coverage.out
coverage.html

# --- Node.js ---
node_modules/
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.vite/

# --- OS Files ---
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db

# --- IDE & Editor ---
.vscode/settings.json
.idea/
*.swp
*.swo
*.suo
*.user

# --- Logs ---
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Misc ---
*.pem
*.key
*.cert

