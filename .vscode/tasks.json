{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "dev",
      "path": "frontend",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\s*VITE\\s+v\\d+\\.\\d+\\.\\d+\\s+ready\\s+in\\s+\\d+\\s*ms",
          "endsPattern": "^\\s*➜\\s+Local:\\s+http://localhost:5173/?"
        }
      },
      "presentation": {
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      }
    }
  ]
}
